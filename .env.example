API_PORT=8787
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
MEMORY_DB_PATH=.data/memory.sqlite

MODEL_PROVIDER=vertex
MODEL_TEMPERATURE=0.2
MODEL_MAX_OUTPUT_TOKENS=2048

VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-2.5-flash
VERTEX_AI_EMBEDDING_MODEL=text-embedding-004

# Kept for the retained OpenAI adapter. Not used unless MODEL_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: openai or vertex. If omitted, the tools module picks the first configured embedding provider.
TOOL_EMBEDDING_PROVIDER=
